# Copy to `.env` and adjust as needed. Loaded by src/insurance_price/config.py.

# Path to the trained model artifact produced by `python -m insurance_price.train`.
MODEL_PATH=models/model.joblib

# Path to the training dataset.
DATA_PATH=data/insurance.csv

# Database connection string.
# Local dev (default): SQLite file in the project root.
DATABASE_URL=sqlite:///./predictions.db
# Production example (Postgres):
# DATABASE_URL=postgresql+psycopg://insurance:insurance@db:5432/insurance
